# Sandbox stack defaults.
# Copy this file to deploy/sandbox/.env to override values locally.

# UI is the only service published to the host by default.
SECAI_UI_PORT=8480

# Optional profiles:
#   scripts/sandbox/start.* --with-inference
#   scripts/sandbox/start.* --with-diffusion
SECAI_INFERENCE_IMAGE_TAG=server
SECAI_INFERENCE_MODEL_PATH=
SECAI_CONTEXT_SIZE=8192
SECAI_GPU_LAYERS=0

SECAI_DIFFUSION_COMPUTE=cpu
