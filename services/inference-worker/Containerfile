# Inference worker: wraps llama-server (llama.cpp) with GPU support.
# Build arg COMPUTE selects the backend:
#   cuda   - NVIDIA GPUs (official llama.cpp CUDA build)
#   rocm   - AMD GPUs (official llama.cpp ROCm build)
#   vulkan - Cross-vendor Vulkan compute (Intel Arc, AMD, NVIDIA)
#   cpu    - CPU only (AVX2/AVX-512/NEON auto-detected, Metal on macOS host)
ARG COMPUTE=cuda

# SECURITY: Cannot digest-pin this image because the tag is dynamic (server-${COMPUTE}).
# Pin each variant when building for production:
#   skopeo inspect docker://ghcr.io/ggerganov/llama.cpp:server-cuda | jq -r '.Digest'
#   skopeo inspect docker://ghcr.io/ggerganov/llama.cpp:server-rocm | jq -r '.Digest'
#   skopeo inspect docker://ghcr.io/ggerganov/llama.cpp:server-cpu  | jq -r '.Digest'
# TODO: pin digest per COMPUTE variant
FROM ghcr.io/ggerganov/llama.cpp:server-${COMPUTE} AS runtime

# The entrypoint script reads appliance.yaml and starts llama-server
# with the correct model path and settings.
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 8465
ENTRYPOINT ["/entrypoint.sh"]
